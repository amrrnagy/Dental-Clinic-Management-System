<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="480.0" prefWidth="800.0" spacing="15" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Nurse.AppointmentViewController">

    <Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Appointment List" />

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button onAction="#handleBackToDashboard" style="-fx-font-weight: bold;" text="← Back to Dashboard" />
        <Separator orientation="VERTICAL" />
        <Label text="Filter by Status:" />
        <ComboBox fx:id="cmbStatusFilter" promptText="All Statuses" />
    </HBox>

    <Separator />

    <TableView fx:id="tblAppointments" prefHeight="315.0" prefWidth="791.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colAppointmentId" prefWidth="143.0" text="Appointment ID" />
            <TableColumn fx:id="colPatient" prefWidth="163.0" text="Patient Name" />
            <TableColumn fx:id="colDoctor" prefWidth="135.0" text="Doctor Name" />
            <TableColumn fx:id="colDateTime" prefWidth="160.0" text="Date &amp; Time" />
            <TableColumn fx:id="colStatus" prefWidth="158.0" text="Status" />
        </columns>
    </TableView>
     <Button onAction="#handleReset" text="Reset" />

</VBox>
