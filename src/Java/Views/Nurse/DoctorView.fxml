<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="500.0" prefWidth="850.0" spacing="15" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Nurse.DoctorViewController">

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Button onAction="#handleBackToDashboard" style="-fx-font-weight: bold; -fx-cursor: hand;" text="← Back to Dashboard" />
        <Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Doctors Management" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f4f4f4; -fx-padding: 10; -fx-background-radius: 5;">

        <Label style="-fx-font-weight: bold;" text="Search ID:" />
        <TextField fx:id="txtSearchId" promptText="ex. DOC1" style="-fx-background-radius: 3;" />
        <Button onAction="#handleSearch" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;" text="Search" />

        <Region HBox.hgrow="ALWAYS" />

        <Button onAction="#handleAdd" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="+ Add Doctor" />
        <Button onAction="#handleRemove" style="-fx-background-color: #af4c4c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="- Remove Selected" />
    </HBox>

    <HBox fx:id="errorContainer" alignment="CENTER" prefHeight="20.0">
        <Label fx:id="lblError" alignment="CENTER" contentDisplay="CENTER">
            <font>
                <Font name="System Bold" size="12.0"/>
            </font>
        </Label>
    </HBox>

    <VBox VBox.vgrow="ALWAYS">
        <TableView fx:id="tblDoctors" prefHeight="293.0" prefWidth="760.0" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colDoctorId" prefWidth="100.0" text="Doctor ID"/>
                <TableColumn fx:id="colName" prefWidth="150.0" text="Name"/>
                <TableColumn fx:id="colGender" prefWidth="100.0" text="Gender"/>
                <TableColumn fx:id="colUsername" prefWidth="120.0" text="Username"/>
                <TableColumn fx:id="colPassword" prefWidth="120.0" text="Password"/>
                <TableColumn fx:id="colSpecialization" prefWidth="160.0" text="Specialization"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

</VBox>