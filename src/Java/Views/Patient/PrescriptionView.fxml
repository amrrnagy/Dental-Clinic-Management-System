<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="500.0" prefWidth="800.0" spacing="15" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Patient.PrescriptionViewController">

    <HBox alignment="CENTER_LEFT" spacing="30.0">
        <Button onAction="#handleBackToDashboard" style="-fx-font-weight: bold;" text="← Back to Dashboard" />
        <Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="My Prescriptions" />
    </HBox>

    <Separator />

    <VBox prefHeight="374.0" prefWidth="660.0" VBox.vgrow="ALWAYS">
        <TableView fx:id="tblPrescriptions" prefHeight="394.0" prefWidth="760.0">
            <columns>
                <TableColumn fx:id="colDate" prefWidth="127.0" text="Date Issued" />
                <TableColumn fx:id="colMedication" prefWidth="121.0" text="Medication" />
                <TableColumn fx:id="colDosage" prefWidth="123.0" text="Dosage" />
                <TableColumn fx:id="colDoctor" prefWidth="188.0" text="Prescribing Doctor" />
                <TableColumn fx:id="colInstructions" prefWidth="200.0" text="Instructions" />
            </columns>
        </TableView>
    </VBox>

</VBox>
