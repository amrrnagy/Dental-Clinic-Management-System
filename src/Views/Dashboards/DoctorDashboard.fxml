<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="315.0" prefWidth="544.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Dashboards.DoctorDashboardController">

    <VBox alignment="TOP_CENTER" layoutX="34.0" layoutY="20.0" prefWidth="578.0" spacing="25" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="34.0" AnchorPane.rightAnchor="34.799999999999955" AnchorPane.topAnchor="20.0">

        <Label style="-fx-font-size: 28pt; -fx-font-weight: bold; -fx-text-fill: #00796b;" text="Doctor Dashboard" />

        <GridPane alignment="CENTER" hgap="40" vgap="20">
            <columnConstraints>
                <ColumnConstraints halignment="CENTER" prefWidth="250" />
                <ColumnConstraints halignment="CENTER" prefWidth="250" />
            </columnConstraints>

            <VBox alignment="CENTER" spacing="10" style="-fx-border-color: #00796b; -fx-border-width: 2; -fx-padding: 20; -fx-background-color: #e0f2f1;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label style="-fx-font-size: 16pt; -fx-font-weight: bold;" text="Prescription" />
                <Text text="Issue new prescriptions for patients." />
                <Button onAction="#handlePrescriptionView" prefWidth="200" style="-fx-background-color: #00897b; -fx-text-fill: white;" text="Manage Prescriptions" />
            </VBox>
         <VBox alignment="CENTER" spacing="10" style="-fx-border-color: #00796b; -fx-border-width: 2; -fx-padding: 20; -fx-background-color: #e0f2f1;">
            <children>
               <Label style="-fx-font-size: 16pt; -fx-font-weight: bold;" text="Appointments" />
               <Text text="View all appointments." />
               <Button onAction="#handleViewSchedule" prefWidth="200" style="-fx-background-color: #00897b; -fx-text-fill: white;" text="View Schedule" />
            </children>
         </VBox>
            <rowConstraints>
                <RowConstraints />
            </rowConstraints>
        </GridPane>

        <Region VBox.vgrow="ALWAYS" />

        <Button onAction="#handleLogout" prefWidth="150" style="-fx-background-color: #e57373; -fx-text-fill: white;" text="Log Out" />
    </VBox>
</AnchorPane>
