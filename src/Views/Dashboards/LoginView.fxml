<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Dashboards.LoginController">

    <HBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <VBox alignment="CENTER" prefHeight="500.0" prefWidth="259.0" style="-fx-background-color: #1976D2;" HBox.hgrow="NEVER">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <Label style="-fx-font-size: 28pt; -fx-font-weight: bold; -fx-text-fill: white;" text="THE" />
            <Label style="-fx-font-size: 28pt; -fx-font-weight: bold; -fx-text-fill: #90CAF9;" text="CLINIC" />
        </VBox>

        <VBox alignment="CENTER" spacing="25" style="-fx-background-color: white;" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="40" left="60" right="60" top="40" />
            </padding>

            <Label style="-fx-font-size: 22pt; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Welcome Back" />
            <Label style="-fx-font-size: 11pt; -fx-text-fill: #757575;" text="Please sign in to your account" />

            <VBox maxWidth="350" spacing="15">

                <VBox spacing="5">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #555555;" text="Role" />
                    <ComboBox fx:id="cmbRole" prefWidth="400" promptText="Select your role" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 5; -fx-padding: 5;" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #555555;" text="Username" />
                    <TextField fx:id="txtUsername" promptText="Enter your username" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 5; -fx-padding: 8;" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #555555;" text="Password" />
                    <PasswordField fx:id="txtPassword" promptText="Enter your password" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 5; -fx-padding: 8;" />
                </VBox>

                <Label fx:id="lblErrorMessage" style="-fx-text-fill: red; -fx-font-size: 10pt;" wrapText="true" />

                <Button defaultButton="true" maxWidth="Infinity" onAction="#handleSignIn" style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20; -fx-cursor: hand; -fx-background-radius: 5;" text="Sign In" textFill="#000000fb">
                    <VBox.margin>
                        <Insets top="10" />
                    </VBox.margin>
                </Button>


            </VBox>

        </VBox>
    </HBox>
</AnchorPane>
