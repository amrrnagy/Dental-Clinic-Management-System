<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="444.0" prefWidth="540.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Dashboards.NurseDashboardController">
    <VBox alignment="TOP_CENTER" layoutX="32.0" layoutY="34.0" prefHeight="388.0" prefWidth="476.0" spacing="30" AnchorPane.bottomAnchor="33.0" AnchorPane.leftAnchor="32.0" AnchorPane.rightAnchor="32.0" AnchorPane.topAnchor="34.0">

        <Label style="-fx-font-size: 26pt; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Nurse Dashboard" />

        <GridPane alignment="CENTER" hgap="30" vgap="30">
            <columnConstraints>
                <ColumnConstraints halignment="CENTER" prefWidth="220" />
                <ColumnConstraints halignment="CENTER" prefWidth="220" />
            </columnConstraints>

            <VBox alignment="CENTER" spacing="15" style="-fx-border-color: #3498db; -fx-border-width: 2; -fx-padding: 20; -fx-background-color: #f7f9fc;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label style="-fx-font-size: 14pt; -fx-font-weight: bold;" text="Patients" />
                <Button onAction="#handleGoToPatientView" prefWidth="180" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Manage Patients" />
            </VBox>

            <VBox alignment="CENTER" spacing="15" style="-fx-border-color: #2ecc71; -fx-border-width: 2; -fx-padding: 20; -fx-background-color: #f7f9fc;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label style="-fx-font-size: 14pt; -fx-font-weight: bold;" text="Doctors" />
                <Button onAction="#handleGoToDoctorView" prefWidth="180" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="Manage Doctors" />
            </VBox>

            <VBox alignment="CENTER" spacing="15" style="-fx-border-color: #9b59b6; -fx-border-width: 2; -fx-padding: 20; -fx-background-color: #f7f9fc;" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label style="-fx-font-size: 14pt; -fx-font-weight: bold;" text="Appointments" />
                <Button onAction="#handleGoToAppointmentView" prefWidth="180" style="-fx-background-color: #9b59b6; -fx-text-fill: white;" text="View Appointments" />
            </VBox>

            <VBox alignment="CENTER" spacing="15" style="-fx-border-color: #f1c40f; -fx-border-width: 2; -fx-padding: 20; -fx-background-color: #f7f9fc;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label style="-fx-font-size: 14pt; -fx-font-weight: bold;" text="Financials" />
                <Button onAction="#handleGoToPaymentView" prefWidth="180" style="-fx-background-color: #f1c40f; -fx-text-fill: white;" text="View Payments" />
            </VBox>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>

        <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Log Out" />
    </VBox>
</AnchorPane>
