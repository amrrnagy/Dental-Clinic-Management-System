<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="465.0" prefWidth="704.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Dashboards.PatientDashboardController">

    <VBox alignment="TOP_CENTER" spacing="25" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">

        <Label style="-fx-font-size: 28pt; -fx-font-weight: bold; -fx-text-fill: #4CAF50;" text="Patient Portal" />

        <GridPane alignment="CENTER" hgap="40" vgap="20">
            <columnConstraints>
                <ColumnConstraints halignment="CENTER" prefWidth="250" />
                <ColumnConstraints halignment="CENTER" prefWidth="250" />
            </columnConstraints>

            <VBox alignment="CENTER" spacing="10" style="-fx-border-color: #4CAF50; -fx-border-width: 2; -fx-padding: 20; -fx-background-color: #e8f5e9;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label style="-fx-font-size: 14pt; -fx-font-weight: bold;" text="My Schedule" />
                <Text text="View upcoming appointments." />
                <Button onAction="#handleViewAppointments" prefWidth="200" style="-fx-background-color: #66bb6a; -fx-text-fill: white;" text="View Appointments" />
            </VBox>

            <VBox alignment="CENTER" spacing="10" style="-fx-border-color: #4CAF50; -fx-border-width: 2; -fx-padding: 20; -fx-background-color: #e8f5e9;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label style="-fx-font-size: 14pt; -fx-font-weight: bold;" text="My Prescriptions" />
                <Text text="Review all current and past prescriptions." />
                <Button onAction="#handleViewPrescriptions" prefWidth="200" style="-fx-background-color: #66bb6a; -fx-text-fill: white;" text="View Prescriptions" />
            </VBox>
            <rowConstraints>
                <RowConstraints />
            </rowConstraints>

        </GridPane>
      <VBox alignment="CENTER" maxWidth="200.0" prefHeight="134.0" prefWidth="629.0" spacing="10" style="-fx-border-color: #4CAF50; -fx-border-width: 2; -fx-padding: 20; -fx-background-color: #e8f5e9;">
         <children>
            <Label style="-fx-font-size: 14pt; -fx-font-weight: bold;" text="Payments" />
            <Text text="Process a payment" />
            <Button onAction="#handleAddPayment" prefWidth="155.0" style="-fx-background-color: #66bb6a; -fx-text-fill: white;" text="Add Payment" />
         </children>
      </VBox>

        <Region VBox.vgrow="ALWAYS" />
        <Button onAction="#handleLogout" prefWidth="150" style="-fx-background-color: #e57373; -fx-text-fill: white;" text="Exit Portal" />
    </VBox>
</AnchorPane>
