<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="453.0" prefWidth="700.0" spacing="15" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Doctor.DoctorPrescriptionController">

    <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="660.0" spacing="30.0">
        <Button onAction="#handleBackToDashboard" style="-fx-font-weight: bold;" text="← Back to Dashboard" />
        <Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Prescriptions" />
      <GridPane prefHeight="51.0" prefWidth="312.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="152.0" minWidth="10.0" prefWidth="103.6" />
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="115.20000000000002" minWidth="10.0" prefWidth="107.20000000000002" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints maxHeight="23.599995040893553" minHeight="3.599996948242186" prefHeight="23.599995040893553" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Button mnemonicParsing="false" prefHeight="39.0" prefWidth="107.0" style="-fx-background-color: #4caf4e; -fx-text-fill: white;" text="Add Prescription" GridPane.columnIndex="2" />
         </children>
      </GridPane>
    </HBox>

    <Separator />

    <VBox prefHeight="374.0" prefWidth="660.0" VBox.vgrow="ALWAYS">
        <TableView fx:id="tblPrescriptions" prefHeight="350.0" prefWidth="660.0">
            <columns>
                <TableColumn fx:id="colDoctor" prefWidth="140.0" text="Patient" />
                <TableColumn fx:id="colDate" prefWidth="120.0" text="Date Issued" />
                <TableColumn fx:id="colMedication" prefWidth="110.0" text="Medication" />
                <TableColumn fx:id="colDosage" prefWidth="100.0" text="Dosage" />
                <TableColumn fx:id="colInstructions" prefWidth="190.0" text="Instructions" />
            </columns>
        </TableView>
    </VBox>

</VBox>
