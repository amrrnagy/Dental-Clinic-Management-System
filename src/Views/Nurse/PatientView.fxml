<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="398.0" prefWidth="600.0" spacing="15" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Nurse.PatientViewController">

    <HBox alignment="CENTER_LEFT" prefHeight="49.0" prefWidth="560.0" spacing="30.0">
        <Button onAction="#handleBackToDashboard" style="-fx-font-weight: bold;" text="← Back to Dashboard" />
        <Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Patients" wrappingWidth="91.21875" />
    </HBox>
   <HBox alignment="CENTER" prefHeight="46.0" prefWidth="560.0" spacing="40.0">
      <children>
         <Button mnemonicParsing="false" prefHeight="34.0" prefWidth="91.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Add" />
         <Button layoutX="260.0" layoutY="15.0" mnemonicParsing="false" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #af4c4c; -fx-text-fill: white;" text="Remove" />
      </children>
   </HBox>

    <VBox VBox.vgrow="ALWAYS">
        <children>
            <TableView fx:id="tblPatients" prefHeight="238.0" prefWidth="588.0">
                <columns>
                    <TableColumn fx:id="colPatientId" prefWidth="68.0" text="Patient ID" />
                    <TableColumn fx:id="colName" prefWidth="82.0" text="Name" />
                    <TableColumn fx:id="colGender" prefWidth="62.0" text="Gender" />
                    <TableColumn fx:id="colPhone" text="Phone" />
                    <TableColumn fx:id="colUsername" prefWidth="69.0" text="username" />
                    <TableColumn fx:id="colPassword" prefWidth="76.0" text="password" />
                    <TableColumn fx:id="colHistory" prefWidth="122.0" text="History" />
                </columns>
            </TableView>
        </children></VBox>

</VBox>
