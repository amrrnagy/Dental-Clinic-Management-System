<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="418.0" prefWidth="496.0" spacing="20" style="-fx-padding: 25;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Patient.AddAppointmentController">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button onAction="#handleBackToDashboard" style="-fx-font-weight: bold;" text="← Back to Dashboard" />

        <Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Schedule New Appointment" />
    </HBox>

    <Separator />
    <GridPane hgap="15" vgap="15">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
        </columnConstraints>

        <Label text="Patient:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <ComboBox fx:id="cmbPatient" promptText="Select Patient" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Doctor:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <ComboBox fx:id="cmbDoctor" promptText="Select Doctor" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Date:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <DatePicker fx:id="dpDate" promptText="Select Date" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label text="Time (HH:MM):" GridPane.columnIndex="0" GridPane.rowIndex="3" />

        <Label text="Reason:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
        <TextArea fx:id="txtReason" prefHeight="70" GridPane.columnIndex="1" GridPane.rowIndex="5" />
      <ComboBox fx:id="cmbSlots" prefWidth="150.0" promptText="Select Slots" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>

    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button fx:id="btnSchedule" onAction="#handleScheduleAppointment" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Schedule Appointment" />
    </HBox>

</VBox>
