<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="168.0" prefWidth="376.0" spacing="15" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Patient.CancelAppointmentController">

    <HBox alignment="CENTER_LEFT" prefHeight="26.0" prefWidth="179.0" spacing="20">
        <Button onAction="#handleBackToDashboard" style="-fx-font-weight: bold;" text="← Back to Dashboard" />
    </HBox>

    <Separator />
    <GridPane hgap="10" prefHeight="154.0" prefWidth="383.0" vgap="10">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="147.20001220703125" minWidth="10.0" prefWidth="58.20001220703125" />
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="336.79998779296875" minWidth="10.0" prefWidth="186.19998779296876" />
        </columnConstraints>

        <Label prefHeight="18.0" prefWidth="83.0" text="Appointment:" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <font>
                <Font name="System Bold" size="12.0" />
            </font></Label>

        <Button onAction="#handleRemovePatient" style="-fx-background-color: #f32121; -fx-text-fill: white;" text="Cancel" GridPane.columnIndex="1" GridPane.halignment="RIGHT" GridPane.rowIndex="2" />
        <ComboBox fx:id="cmbPatient" prefHeight="26.0" prefWidth="227.0" promptText="Select an Appointment to Cancel" GridPane.columnIndex="1" />
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>

    </GridPane>

</VBox>
