<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="465.0" prefWidth="788.0" spacing="15" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Patient.PatientAppointmentController">

    <Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Appointment List" />

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button onAction="#handleBackToDashboard" style="-fx-font-weight: bold;" text="← Back to Dashboard" />
        <Separator orientation="VERTICAL" />
        <Label text="Filter by Status:" />
        <ComboBox fx:id="cmbStatusFilter" promptText="All Statuses" />
        <Button onAction="#handleRefreshList" text="Refresh List" />
        <Button onAction="#handleNewAppointment" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="New Appointment" />
      <Button layoutX="466.0" layoutY="10.0" onAction="#handleCancelappointment" style="-fx-background-color: #af4c4c; -fx-text-fill: white;" text="Cancel Appointment" />
    </HBox>

    <Separator />
   <HBox fx:id="errorContainer" alignment="CENTER" prefHeight="21.0" prefWidth="582.0">
      <children>
         <Label fx:id="lblError" alignment="CENTER" contentDisplay="CENTER">
            <font>
               <Font name="System Bold" size="12.0" />
            </font>
         </Label>
      </children>
   </HBox>

    <TableView fx:id="tblAppointments" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colAppointmentId" prefWidth="189.0" text="Appointment ID" />
            <TableColumn fx:id="colDateTime" prefWidth="180.0" text="Date &amp; Time" />
            <TableColumn fx:id="colDoctor" prefWidth="177.0" text="Doctor Name" />
            <TableColumn fx:id="colStatus" prefWidth="188.0" text="Status" />
        </columns>
    </TableView>

</VBox>
